{
  "title": "Project Management API",
  "uid": "pm-api-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (method, route)",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (4xx/5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"4..|5..\"}[1m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "HTTP Response Time p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[5m])) by (le, route))",
          "legendFormat": "p95 {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "HTTP Response Time p50 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_ms_bucket[5m])) by (le, route))",
          "legendFormat": "p50 {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 5,
      "title": "BullMQ Jobs / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(bullmq_jobs_total[1m])) by (queue, status)",
          "legendFormat": "{{queue}} / {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 6,
      "title": "BullMQ Job Duration p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(bullmq_job_duration_ms_bucket[5m])) by (le, queue))",
          "legendFormat": "p95 {{queue}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 7,
      "title": "Node.js Heap Used (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes / 1024 / 1024",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "nodejs_heap_size_total_bytes / 1024 / 1024",
          "legendFormat": "Heap Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 8,
      "title": "Node.js Event Loop Lag (ms)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds * 1000",
          "legendFormat": "Event Loop Lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 9,
      "title": "Node.js Active Handles",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "nodejs_active_handles_total",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 10,
      "title": "Redis Connected Clients",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Connected Clients"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 11,
      "title": "Redis Memory Used (MB)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 32, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / 1024 / 1024",
          "legendFormat": "Memory Used"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 12,
      "title": "Redis Commands / sec",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 32, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "Commands/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 13,
      "title": "MongoDB Operations / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 40, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(mongodb_op_counters_total[1m])",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 14,
      "title": "MongoDB Connections",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 40, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "mongodb_connections{state=\"current\"}",
          "legendFormat": "Current"
        },
        {
          "expr": "mongodb_connections{state=\"available\"}",
          "legendFormat": "Available"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      }
    }
  ]
}
